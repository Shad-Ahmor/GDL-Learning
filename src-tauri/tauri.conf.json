{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GDLLearning ERP",
  "version": "1.3.0",
  "identifier": "com.gdll.learning",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GDLLearning ERP - Professional Edition",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "fullscreen": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "externalBin": ["bin/node"],
    "resources": ["../src-sidecar", "../src-sidecar/node_modules", "../prisma"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": true
      }
    }
  }
}
